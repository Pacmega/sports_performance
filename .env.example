# Environment Variables

# API Keys (add as needed)
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=

# Database (if using PostgreSQL)
# DATABASE_URL=postgresql://user:pass@localhost/sports_performance

# Scraping
# RATE_LIMIT_REQUESTS_PER_SECOND=2
# USER_AGENT="Sports Performance Tool (contact@example.com)"

# Optional features
# DEBUG=false